# ──────────────────────────────────────────────────
# FastRabbit 模型供应商配置
# 复制此文件为 .env 并填入你的 API Key
# ──────────────────────────────────────────────────

# ── LLM（大语言模型）───────────────────────────────
# 用于：剧本拆解、角色提取、镜头分镜、提示词生成
# 支持任何兼容 OpenAI SDK 的 API（DeepSeek / OpenAI / 本地模型等）
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=sk-你的key
LLM_BASE_URL=https://api.deepseek.com

# ── 生图（图片生成）────────────────────────────────
# 用于：角色立绘图、场景背景图
# 当前对接 Nano Banana API
IMAGE_PROVIDER=nano-banana
IMAGE_MODEL=nano-banana-fast
IMAGE_API_KEY=sk-你的key
IMAGE_BASE_URL=https://grsai.dakka.com.cn/v1/draw/nano-banana

# ── 视频生成 ──────────────────────────────────────
# 用于：镜头视频生成
# 当前对接火山方舟 ARK Seedance
VIDEO_PROVIDER=ark
VIDEO_MODEL=doubao-seedance-2-0-250528
VIDEO_API_KEY=你的key
VIDEO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── 视频风格参考（可选）────────────────────────────
# 提供一个参考视频 URL，所有 scene 的第一个镜头将使用该视频
# 作为运动/风格参考，帮助统一运镜和色调
# VIDEO_REFERENCE_URL=https://example.com/style-reference.mp4
